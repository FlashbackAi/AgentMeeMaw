# ============================================================================
# .env.example
# Flashback AI: Legacy Mode  -  agent service configuration
# ----------------------------------------------------------------------------
# Copy to .env (or export from your shell / secrets manager) before running:
#
#     python -m flashback.workers.embedding run
#     python -m flashback.workers.embedding backfill --dry-run
#
# Every model selection and queue endpoint lives here. The worker reads
# only environment variables - no config files. Changing the embedding
# model in production is a two-step ritual:
#
#   1. Update EMBEDDING_MODEL / EMBEDDING_MODEL_VERSION here.
#   2. Run `backfill` to enqueue re-embeds for everything still on the
#      old identity. The worker's version-guarded UPDATE handles the rest.
# ============================================================================


# --- Required ---------------------------------------------------------------

# Postgres canonical graph (writes). Must include sslmode= and the
# right user/password for production. The `vector` and `pgcrypto`
# extensions must already be installed on the database.
DATABASE_URL=postgresql://flashback:flashback@localhost:15432/flashback

# SQS queue URL for the embedding queue. The worker drains this; the
# backfill CLI publishes to it.
EMBEDDING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/flashback-embedding

# Voyage AI API key. Get one from https://dash.voyageai.com.
VOYAGE_API_KEY=changeme

# OpenAI API key. Small LLM calls use OpenAI by default.
OPENAI_API_KEY=changeme

# Anthropic API key. Big LLM calls use Anthropic by default.
ANTHROPIC_API_KEY=changeme


# --- Embedding model identity ----------------------------------------------
# These two are stamped onto every embedded row alongside the vector.
# Changing them is the documented way to roll forward.

EMBEDDING_MODEL=voyage-3-large

# Free-text version tag. Voyage doesn't publish dated snapshots the
# way Anthropic does, so we treat this as an opaque string. Conventional
# choice: the public-release date of the model snapshot you started on.
EMBEDDING_MODEL_VERSION=2025-01-07


# --- AWS --------------------------------------------------------------------

AWS_REGION=us-east-1


# --- Tuning (optional - sensible defaults) ----------------------------------

# Up to 10 messages per long-poll receive. SQS hard cap is 10.
SQS_MAX_MESSAGES=10

# Long-poll timeout. 20 is the SQS hard cap. Lower it only for tests.
SQS_WAIT_SECONDS=20

# Connection-pool size. A single embedding worker process needs almost
# nothing here.
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=4


# --- HTTP service (step 4) --------------------------------------------------

# Where the agent service binds. The service speaks only to Node over an
# internal network; do not expose it to the public internet.
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# Shared bearer token. Node sends this in the X-Service-Token header on
# every request. Mismatched / missing -> 401. Defense-in-depth; the real
# auth boundary is Node + private network. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SERVICE_TOKEN=changeme

# Valkey connection string. Valkey is API-compatible with Redis 7.2.
# DB 0 is fine; we only use string + list + hash.
VALKEY_URL=redis://localhost:6379/0

# Working Memory TTL. Sessions are short-lived; TTL is GC for orphaned
# session keys. Refreshed on every write that touches the key.
WORKING_MEMORY_TTL_SECONDS=86400

# How many turns to keep in the rolling transcript buffer in WM. Older
# turns are compressed into the rolling_summary.
WORKING_MEMORY_TRANSCRIPT_LIMIT=30


# --- LLM routing ------------------------------------------------------------

# Shared defaults by call size. Components can override only their model while
# inheriting the provider class.
LLM_SMALL_PROVIDER=openai
LLM_SMALL_MODEL=gpt-5-mini
LLM_BIG_PROVIDER=anthropic
LLM_BIG_MODEL=claude-sonnet-4-6

# Intent Classifier: hot-path small call.
LLM_INTENT_MODEL=gpt-5-mini
LLM_INTENT_TIMEOUT_SECONDS=8
LLM_INTENT_MAX_TOKENS=300

# Response Generator: big plain-text call. Failures surface as HTTP 503
# rather than a canned fallback.
LLM_RESPONSE_PROVIDER=anthropic
LLM_RESPONSE_MODEL=claude-sonnet-4-6
LLM_RESPONSE_TIMEOUT_SECONDS=12
LLM_RESPONSE_MAX_TOKENS=400


# --- Retrieval Service ------------------------------------------------------

# Hard timeout for Voyage query embeddings on the turn hot path. If this
# times out or Voyage errors, similarity retrieval returns no context and
# the turn continues.
RETRIEVAL_QUERY_EMBED_TIMEOUT_SECONDS=2

# Default and defensive hard cap for retrieval result limits.
RETRIEVAL_DEFAULT_LIMIT=10
RETRIEVAL_MAX_LIMIT=50


# --- Tests only -------------------------------------------------------------
# Tests skip if this is unset. Point at a throwaway database with the
# pgvector extension installed; the test suite drops and recreates the
# `public` schema, then applies all migrations from migrations/.

TEST_DATABASE_URL=postgresql://flashback:flashback@localhost:15432/flashback_test
