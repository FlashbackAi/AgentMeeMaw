# ============================================================================
# .env.example
# Flashback AI: Legacy Mode  -  agent service configuration
# ----------------------------------------------------------------------------
# Copy to .env (or export from your shell / secrets manager) before running:
#
#     python -m flashback.workers.embedding run
#     python -m flashback.workers.embedding backfill --dry-run
#
# Every model selection and queue endpoint lives here. The worker reads
# only environment variables - no config files. Changing the embedding
# model in production is a two-step ritual:
#
#   1. Update EMBEDDING_MODEL / EMBEDDING_MODEL_VERSION here.
#   2. Run `backfill` to enqueue re-embeds for everything still on the
#      old identity. The worker's version-guarded UPDATE handles the rest.
# ============================================================================


# --- Required ---------------------------------------------------------------

# Postgres canonical graph (writes). Must include sslmode= and the
# right user/password for production. The `vector` and `pgcrypto`
# extensions must already be installed on the database.
DATABASE_URL=postgresql://flashback:flashback@localhost:15432/flashback

# SQS queue URL for the embedding queue. The worker drains this; the
# backfill CLI publishes to it.
EMBEDDING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/flashback-embedding

# SQS queue URL for the extraction queue. The Segment Detector publishes
# closed segments here; the Extraction Worker drains it in step 11.
EXTRACTION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/flashback-extraction

# SQS queue URL for the artifact_generation queue. The Extraction
# Worker publishes per-row generation prompts here; Node consumes them.
ARTIFACT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/flashback-artifact

# SQS queue URL for the thread_detector queue. The Extraction Worker
# pushes one trigger message here per legacy whose new active-moment
# count crosses the 15-since-last-run gate; the Thread Detector worker
# (step 12) drains it.
THREAD_DETECTOR_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/flashback-thread-detector

# Voyage AI API key. Get one from https://dash.voyageai.com.
VOYAGE_API_KEY=changeme

# OpenAI API key. Small LLM calls use OpenAI by default.
OPENAI_API_KEY=changeme

# Anthropic API key. Big LLM calls use Anthropic by default.
ANTHROPIC_API_KEY=changeme


# --- Embedding model identity ----------------------------------------------
# These two are stamped onto every embedded row alongside the vector.
# Changing them is the documented way to roll forward.

EMBEDDING_MODEL=voyage-3-large

# Free-text version tag. Voyage doesn't publish dated snapshots the
# way Anthropic does, so we treat this as an opaque string. Conventional
# choice: the public-release date of the model snapshot you started on.
EMBEDDING_MODEL_VERSION=2025-01-07


# --- AWS --------------------------------------------------------------------

AWS_REGION=us-east-1

# LocalStack / local SQS. Uncomment for host-run local integration tests.
# Use http://localstack:4566 instead when the Python service itself runs
# inside docker compose.
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# SQS_ENDPOINT_URL=http://localhost:4566
# EMBEDDING_QUEUE_URL=http://localhost:4566/000000000000/flashback-embedding
# EXTRACTION_QUEUE_URL=http://localhost:4566/000000000000/flashback-extraction
# ARTIFACT_QUEUE_URL=http://localhost:4566/000000000000/flashback-artifact
# THREAD_DETECTOR_QUEUE_URL=http://localhost:4566/000000000000/flashback-thread-detector
# TRAIT_SYNTHESIZER_QUEUE_URL=http://localhost:4566/000000000000/flashback-trait-synthesizer
# PROFILE_SUMMARY_QUEUE_URL=http://localhost:4566/000000000000/flashback-profile-summary
# PRODUCERS_PER_SESSION_QUEUE_URL=http://localhost:4566/000000000000/flashback-producers-per-session
# PRODUCERS_WEEKLY_QUEUE_URL=http://localhost:4566/000000000000/flashback-producers-weekly


# --- Tuning (optional - sensible defaults) ----------------------------------

# Up to 10 messages per long-poll receive. SQS hard cap is 10.
SQS_MAX_MESSAGES=10

# Long-poll timeout. 20 is the SQS hard cap. Lower it only for tests.
SQS_WAIT_SECONDS=20

# Connection-pool size. A single embedding worker process needs almost
# nothing here.
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=4


# --- HTTP service (step 4) --------------------------------------------------

# Where the agent service binds. The service speaks only to Node over an
# internal network; do not expose it to the public internet.
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# Shared bearer token. Node sends this in the X-Service-Token header on
# every request. Mismatched / missing -> 401. Defense-in-depth; the real
# auth boundary is Node + private network. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SERVICE_TOKEN=changeme

# Local-only escape hatch for end-to-end testing without auth headers.
# Keep unset/false outside local development.
SERVICE_TOKEN_AUTH_DISABLED=false

# Valkey connection string. Valkey is API-compatible with Redis 7.2.
# DB 0 is fine; we only use string + list + hash.
VALKEY_URL=redis://localhost:6379/0

# Working Memory TTL. Sessions are short-lived; TTL is GC for orphaned
# session keys. Refreshed on every write that touches the key.
WORKING_MEMORY_TTL_SECONDS=86400

# How many turns to keep in the rolling transcript buffer in WM. Older
# turns are compressed into the rolling_summary.
WORKING_MEMORY_TRANSCRIPT_LIMIT=30


# --- LLM routing ------------------------------------------------------------

# Shared defaults by call size. Components can override only their model while
# inheriting the provider class.
LLM_SMALL_PROVIDER=openai
LLM_SMALL_MODEL=gpt-5.1
LLM_BIG_PROVIDER=anthropic
LLM_BIG_MODEL=claude-sonnet-4-6

# Intent Classifier: hot-path small call.
LLM_INTENT_MODEL=gpt-5.1
LLM_INTENT_TIMEOUT_SECONDS=8
LLM_INTENT_MAX_TOKENS=800

# Segment Detector: small tool call after the segment buffer threshold.
LLM_SEGMENT_DETECTOR_PROVIDER=openai
LLM_SEGMENT_DETECTOR_MODEL=gpt-5.1
LLM_SEGMENT_DETECTOR_TIMEOUT_SECONDS=10
LLM_SEGMENT_DETECTOR_MAX_TOKENS=1000

# Fixed cadence for the Segment Detector. The detector runs every N
# user turns (1 turn = one user message + one assistant reply). Counter
# is incremented in append_user_turn and reset after every detector run.
SEGMENT_DETECTOR_USER_TURN_CADENCE=6

# Response Generator: big plain-text call. Failures surface as HTTP 503
# rather than a canned fallback.
LLM_RESPONSE_PROVIDER=anthropic
LLM_RESPONSE_MODEL=claude-sonnet-4-6
LLM_RESPONSE_TIMEOUT_SECONDS=12
LLM_RESPONSE_MAX_TOKENS=400

# Session Summary Generator: big plain-text call during /session/wrap.
# Produces the short fragment Node stores for the next opener:
# "Last time, you talked about [fragment]."
LLM_SESSION_SUMMARY_PROVIDER=anthropic
LLM_SESSION_SUMMARY_MODEL=claude-sonnet-4-6
LLM_SESSION_SUMMARY_TIMEOUT_SECONDS=12
LLM_SESSION_SUMMARY_MAX_TOKENS=600

# Extraction Worker (step 11): big LLM tool call per closed segment.
# Provider/model default to the LLM_BIG_* family; override only if you
# want extraction on a different model than other big calls.
LLM_EXTRACTION_PROVIDER=anthropic
LLM_EXTRACTION_MODEL=claude-sonnet-4-6
LLM_EXTRACTION_TIMEOUT_SECONDS=45
LLM_EXTRACTION_MAX_TOKENS=4000

# Compatibility check: small LLM call, fires once per refinement
# candidate found by vector search. Most segments fire it 0 times.
LLM_COMPATIBILITY_PROVIDER=openai
LLM_COMPATIBILITY_MODEL=gpt-5.1
LLM_COMPATIBILITY_TIMEOUT_SECONDS=8
LLM_COMPATIBILITY_MAX_TOKENS=800


# --- Extraction Worker tunables (step 11) ----------------------------------

# Cosine-distance ceiling for refinement candidate search. Lower = stricter.
# 0.35 is a starting guess; tune based on observed false refinements vs
# missed merges.
EXTRACTION_REFINEMENT_DISTANCE_THRESHOLD=0.35

# Top-K cap on the vector search before the entity-overlap filter.
EXTRACTION_REFINEMENT_CANDIDATE_LIMIT=3

# Hard timeout for the in-process Voyage *query* embedding used by the
# refinement search. Voyage failure here returns an empty candidate list
# (the new moment is persisted as independent rather than supersession).
EXTRACTION_VOYAGE_QUERY_TIMEOUT_SECONDS=5


# --- Thread Detector tunables (step 12) ------------------------------------

# HDBSCAN min_cluster_size. A thread needs at least this many supporting
# moments to be worth detecting.
THREAD_DETECTOR_MIN_CLUSTER_SIZE=3

# Cosine distance threshold for matching a cluster centroid to an
# existing active thread. Below this → link to the existing thread;
# at or above → name a new thread.
THREAD_DETECTOR_EXISTING_MATCH_DISTANCE=0.4

# Naming LLM (Sonnet by default). One call per NEW cluster.
LLM_THREAD_NAMING_PROVIDER=anthropic
LLM_THREAD_NAMING_MODEL=claude-sonnet-4-6
LLM_THREAD_NAMING_TIMEOUT_SECONDS=30
LLM_THREAD_NAMING_MAX_TOKENS=800

# P4 thread_deepen LLM (Sonnet by default). One call per AFFECTED thread
# (new OR existing).
LLM_P4_PROVIDER=anthropic
LLM_P4_MODEL=claude-sonnet-4-6
LLM_P4_TIMEOUT_SECONDS=30
LLM_P4_MAX_TOKENS=800


# --- Trait Synthesizer (step 13) -------------------------------------------

# SQS queue URL for the trait_synthesizer queue. Producer is Session Wrap
# (step 16, not yet wired). Consumer is the Trait Synthesizer worker.
# Required for `run`; can be empty for `run-once --person-id <uuid>`.
TRAIT_SYNTHESIZER_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/flashback-trait-synthesizer

# Trait synthesis is a small classification-heavy LLM call: gpt-5.1.
# Defaults inherit LLM_SMALL_*; override only if you want a different model.
LLM_TRAIT_SYNTH_PROVIDER=openai
LLM_TRAIT_SYNTH_MODEL=gpt-5.1
LLM_TRAIT_SYNTH_TIMEOUT_SECONDS=15
LLM_TRAIT_SYNTH_MAX_TOKENS=1500


# --- Profile Summary Generator (step 14) -----------------------------------

# SQS queue URL for the profile_summary queue. Producer is Session Wrap
# (step 16, not yet wired). Consumer is the Profile Summary Generator
# worker. Required for `run`; can be empty for `run-once --person-id`.
PROFILE_SUMMARY_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/flashback-profile-summary

# Profile summaries are user-facing prose shown at the top of the legacy
# view. Quality matters — we use Sonnet by default. Defaults inherit
# LLM_BIG_*; override only if you want a different model here.
LLM_PROFILE_SUMMARY_PROVIDER=anthropic
LLM_PROFILE_SUMMARY_MODEL=claude-sonnet-4-6
LLM_PROFILE_SUMMARY_TIMEOUT_SECONDS=30
LLM_PROFILE_SUMMARY_MAX_TOKENS=600

# Caps on how many of each input class are surfaced to the LLM.
PROFILE_SUMMARY_TOP_TRAITS_MAX=7
PROFILE_SUMMARY_TOP_THREADS_MAX=5
PROFILE_SUMMARY_TOP_ENTITIES_MAX=8

# Profile-fact extraction is the second LLM call inside the
# profile_summary worker. Small structured-output (forced tool call).
# Defaults inherit LLM_SMALL_*. Returns up to 5 high-confidence
# (question, answer) facts per person per run, written to profile_facts.
LLM_PROFILE_FACTS_PROVIDER=openai
LLM_PROFILE_FACTS_MODEL=gpt-5.1
LLM_PROFILE_FACTS_TIMEOUT_SECONDS=15
LLM_PROFILE_FACTS_MAX_TOKENS=800


# --- Question Producers P2/P3/P5 (step 15) ---------------------------------

# P2 is per-session; P3 and P5 share the weekly queue. Producers are
# selected by the message body field: {"person_id": "...", "producer": "P2"}.
# Required for their respective long-running workers; optional for run-once.
PRODUCERS_PER_SESSION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/flashback-producers-per-session
PRODUCERS_WEEKLY_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/flashback-producers-weekly

# Small structured-output LLM call shared by P2/P3/P5. Defaults inherit
# LLM_SMALL_*.
LLM_PRODUCER_PROVIDER=openai
LLM_PRODUCER_MODEL=gpt-5.1
LLM_PRODUCER_TIMEOUT_SECONDS=30
LLM_PRODUCER_MAX_TOKENS=3000

# P2: underdeveloped entities.
P2_MAX_ENTITIES_PER_RUN=3
P2_QUESTIONS_PER_ENTITY=2

# P3: chronology gaps.
P3_MAX_GAPS_PER_RUN=3
P3_QUESTIONS_PER_GAP=4

# P5: universal dimension coverage. A dimension is under-covered when
# fewer than this many active moments+threads match its v1 keyword map.
P5_MAX_DIMENSIONS_PER_RUN=5
P5_QUESTIONS_PER_DIMENSION=2
P5_DIMENSION_COVERAGE_THRESHOLD=3


# --- Retrieval Service ------------------------------------------------------

# Hard timeout for Voyage query embeddings on the turn hot path. If this
# times out or Voyage errors, similarity retrieval returns no context and
# the turn continues.
RETRIEVAL_QUERY_EMBED_TIMEOUT_SECONDS=2

# Default and defensive hard cap for retrieval result limits.
RETRIEVAL_DEFAULT_LIMIT=10
RETRIEVAL_MAX_LIMIT=50


# --- Tests only -------------------------------------------------------------
# Tests skip if this is unset. Point at a throwaway database with the
# pgvector extension installed; the test suite drops and recreates the
# `public` schema, then applies all migrations from migrations/.

TEST_DATABASE_URL=postgresql://flashback:flashback@localhost:15432/flashback_test
